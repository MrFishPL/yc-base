{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit(kb/**)",
      "Edit(transcripts/clean/**)",
      "Write(kb/**)",
      "Write(transcripts/clean/**)",
      "Write(data/**)",
      "Bash(python3 scripts/*)",
      "Bash(rg:*)",
      "Bash(yt-dlp:*)",
      "Bash(scripts/acquire.sh:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(transcripts/raw/**)",
      "Write(transcripts/raw/**)",
      "Bash(rm -rf:*)"
    ]
  }
}
